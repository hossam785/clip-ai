generator client {
  provider = "prisma-client-js"
  output   = "../apps/api/node_modules/.prisma/client"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                  String              @id @default(uuid())
  email               String              @unique
  passwordHash        String
  role                String              @default("USER") // ADMIN, USER
  credits             Int                 @default(100)
  monthlyCredits      Int                 @default(0)
  bonusCredits        Int                 @default(0)
  lifetimeCreditsUsed Int                 @default(0)
  referralCode        String?             @unique
  referredById        String?
  referredBy          User?               @relation("UserReferrals", fields: [referredById], references: [id], onDelete: SetNull)
  referrals           User[]              @relation("UserReferrals")
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  projects            Project[]
  subscription        Subscription?
  transactions        CreditTransaction[]
  usageLogs           UsageLog[]
  brandKits           BrandKit[]
  workspaceMemberships WorkspaceMember[]
  payments            Payment[]
  invoices            Invoice[]
  billingEvents       BillingEvent[]
  connectedAccounts   ConnectedAccount[]
  apiKeys             ApiKey[]
  webhooks            WebhookSubscription[]
  workflowRules       WorkflowRule[]

  @@index([email])
}

model Project {
  id              String             @id @default(uuid())
  name            String
  userId          String
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId     String?
  workspace       Workspace?         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  status          String             @default("DRAFT") // DRAFT, DOWNLOADING, DOWNLOADED, PROCESSING, COMPLETED, FAILED
  isArchived      Boolean            @default(false)
  processingState String?            @default("QUEUED")
  youtubeUrl      String?
  mode            String             @default("AUTO") // AUTO, MANUAL
  maxDuration     String             @default("60")
  effects         Boolean            @default(false)
  videoTitle      String?
  videoDuration   String?
  videoSize       String?
  videoQuality    String?
  thumbnailUrl    String?
  localVideoPath  String?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  clips                 Clip[]
  videos                Video[]
  usageLogs             UsageLog[]
  transcript            Transcript?
  transcribedMinutes    Float              @default(0)
  transcriptionDuration Float              @default(0)
  bestClipScore         Int                @default(0)
  categoriesFound       String?
  aiProcessingStatus    String?
  aiAnalysisMinutes     Float              @default(0)
  clipGenerationCount   Int                @default(0)
  exportCount           Int                @default(0)

  @@index([userId])
  @@index([status])
  @@index([isArchived])
  @@index([workspaceId])
}

model Transcript {
  id                String                @id @default(uuid())
  projectId         String                @unique
  project           Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  text              String
  detectedLanguage  String?
  confidence        Float?
  averageSpeedWpm   Float?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  paragraphs        TranscriptParagraph[]
  sentences         TranscriptSentence[]
  words             TranscriptWord[]
  speakerSegments   SpeakerSegment[]
  silenceSegments   SilenceSegment[]
  topicSegments     TopicSegment[]
}

model TranscriptParagraph {
  id           String     @id @default(uuid())
  transcriptId String
  transcript   Transcript @relation(fields: [transcriptId], references: [id], onDelete: Cascade)
  text         String
  startTime    Float
  endTime      Float

  @@index([transcriptId])
}

model TranscriptSentence {
  id           String     @id @default(uuid())
  transcriptId String
  transcript   Transcript @relation(fields: [transcriptId], references: [id], onDelete: Cascade)
  text         String
  startTime    Float
  endTime      Float
  speakerId    String?

  @@index([transcriptId])
}

model TranscriptWord {
  id           String     @id @default(uuid())
  transcriptId String
  transcript   Transcript @relation(fields: [transcriptId], references: [id], onDelete: Cascade)
  word         String
  startTime    Float
  endTime      Float
  speakerId    String?
  confidence   Float?

  @@index([transcriptId])
  @@index([word])
}

model SpeakerSegment {
  id           String     @id @default(uuid())
  transcriptId String
  transcript   Transcript @relation(fields: [transcriptId], references: [id], onDelete: Cascade)
  speakerId    String // "SPEAKER_A", "SPEAKER_B"
  startTime    Float
  endTime      Float

  @@index([transcriptId])
}

model SilenceSegment {
  id           String     @id @default(uuid())
  transcriptId String
  transcript   Transcript @relation(fields: [transcriptId], references: [id], onDelete: Cascade)
  startTime    Float
  endTime      Float

  @@index([transcriptId])
}

model TopicSegment {
  id           String     @id @default(uuid())
  transcriptId String
  transcript   Transcript @relation(fields: [transcriptId], references: [id], onDelete: Cascade)
  topic        String
  summary      String?
  startTime    Float
  endTime      Float

  @@index([transcriptId])
}

model Video {
  id           String   @id @default(uuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title        String
  duration     String
  size         String
  quality      String
  resolution   String?
  fps          Float?
  uploadSource String? // "UPLOAD" or "YOUTUBE"
  bytesSize    Int      @default(0)
  url          String?
  localPath    String?
  thumbnailUrl String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([projectId])
}

model BackgroundJob {
  id          String   @id @default(uuid())
  projectId   String
  videoId     String?
  type        String // METADATA_EXTRACTION, AI_PROCESSING_SIMULATION
  status      String   @default("QUEUED") // QUEUED, RUNNING, COMPLETED, FAILED
  attempts    Int      @default(0)
  maxAttempts Int      @default(3)
  error       String?
  logs        String   @default("") // JSON string array of steps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([projectId])
}

model Clip {
  id              String   @id @default(uuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title           String
  description     String   @default("")
  hashtags        String   @default("")
  startTime       String
  endTime         String
  viralScore      Int      @default(90)
  engagementScore Int      @default(85)
  hookScore       Int      @default(88)
  retentionScore  Int      @default(80)
  confidenceScore Int      @default(92)
  duration        String
  explanation     String   @default("")
  words           String   @default("") // JSON array of word objects
  category        String   @default("GENERAL")
  isFavorite      Boolean  @default(false)
  infoDensityScore Int     @default(0)
  emotionalScore  Int      @default(0)
  storyScore      Int      @default(0)
  clarityScore    Int      @default(0)
  relevanceScore  Int      @default(0)
  videoPath720p   String?
  videoPath1080p  String?
  selectedTemplate String? @default("MINIMAL")
  brandKitId       String?
  captionSettings  String? // JSON string
  exportSettings   String? // JSON string
  reframeAspect    String? @default("9:16")
  layoutMode       String? @default("AUTO")
  reframeSettings  String? // JSON string
  trackingData     String? // JSON string
  cameraDecisions  String? // JSON string
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  publishedPosts   PublishedPost[]
  schedules        PostSchedule[]

  @@index([projectId])
}

model Subscription {
  id                 String   @id @default(uuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan               String   @default("FREE") // FREE, STARTER, PRO, ENTERPRISE
  status             String   @default("ACTIVE") // ACTIVE, CANCELED, PAST_DUE
  priceId            String?
  stripeSubscriptionId String?
  cancelAtPeriodEnd  Boolean  @default(false)
  stripeCustomerId   String?
  currentPeriodStart DateTime @default(now())
  currentPeriodEnd   DateTime
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([userId])
}

model CreditTransaction {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount      Int
  type        String // SIGNUP_BONUS, PURCHASE, CLIP_GENERATION, MANUAL_ADJUSTMENT
  description String
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model UsageLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  action    String // VIDEO_IMPORT, CLIP_GENERATION, EFFECTS_RENDER
  amount    Int // minutes processed or credits used
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([projectId])
  @@index([createdAt])
}

model GeminiKey {
  id            String    @id @default(uuid())
  key           String    @unique
  status        String    @default("ACTIVE") // ACTIVE, INACTIVE
  requestsCount Int       @default(0)
  successCount  Int       @default(0)
  failedCount   Int       @default(0)
  consumption   Int       @default(0)
  lastUsed      DateTime?
  errorMessage  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model SystemConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model BrandKit {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  logoUrl        String?
  primaryColor   String   @default("#8b5cf6")
  secondaryColor String   @default("#06b6d4")
  textColor      String   @default("#ffffff")
  watermarkText  String?
  fontFamily     String   @default("Inter")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
}

model SubscriptionPlan {
  id                   String   @id @default(uuid())
  name                 String   @unique
  monthlyPrice         Float    @default(0)
  annualPrice          Float    @default(0)
  credits              Int      @default(0)
  uploadLimitCount     Int      @default(0)
  storageLimitMb       Float    @default(0)
  processingLimitMin   Float    @default(0)
  exportLimitCount     Int      @default(0)
  teamMemberLimit      Int      @default(0)
  priorityLevel        String   @default("MEDIUM")
  features             String   @default("[]")
  stripeMonthlyPriceId String?
  stripeAnnualPriceId  String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Workspace {
  id        String            @id @default(uuid())
  name      String
  ownerId   String
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  members   WorkspaceMember[]
  projects  Project[]
}

model WorkspaceMember {
  id          String    @id @default(uuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        String    @default("VIEWER") // OWNER, ADMIN, EDITOR, VIEWER
  status      String    @default("INVITED") // INVITED, ACTIVE
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
}

model PromoCode {
  id             String    @id @default(uuid())
  code           String    @unique
  discountType   String
  discountValue  Float
  expiresAt      DateTime?
  maxRedemptions Int?
  redemptions    Int       @default(0)
  createdAt      DateTime  @default(now())
}

model ReferralReward {
  id             String   @id @default(uuid())
  referrerId     String
  referredUserId String
  creditsAwarded Int
  status         String   @default("PENDING")
  createdAt      DateTime @default(now())
}

model Payment {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeSessionId String?  @unique
  amount          Float
  currency        String   @default("usd")
  status          String
  paymentMethod   String?
  description     String?
  createdAt       DateTime @default(now())

  @@index([userId])
}

model Invoice {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoiceNumber String    @unique
  amount        Float
  status        String
  pdfUrl        String?
  paymentDate   DateTime?
  createdAt     DateTime  @default(now())

  @@index([userId])
}

model BillingEvent {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventType String
  metadata  String   @default("{}")
  createdAt DateTime @default(now())

  @@index([userId])
}

model ConnectedAccount {
  id           String    @id @default(uuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider     String    // "youtube", "tiktok", "instagram", "facebook", "linkedin", "x"
  accountId    String
  accountName  String
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([userId, provider, accountId])
  @@index([userId])
}

model PublishedPost {
  id           String    @id @default(uuid())
  userId       String
  clipId       String
  clip         Clip      @relation(fields: [clipId], references: [id], onDelete: Cascade)
  provider     String    // "youtube", "tiktok", "instagram", "facebook", "linkedin", "x"
  postId       String?
  status       String    @default("PUBLISHED") // PUBLISHED, FAILED
  postUrl      String?
  title        String?
  description  String?
  errorMessage String?
  
  views        Int       @default(0)
  likes        Int       @default(0)
  comments     Int       @default(0)
  shares       Int       @default(0)
  watchTimeSec Int       @default(0)
  retentionRate Float     @default(0)
  
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId])
  @@index([clipId])
}

model PostSchedule {
  id           String    @id @default(uuid())
  userId       String
  clipId       String
  clip         Clip      @relation(fields: [clipId], references: [id], onDelete: Cascade)
  provider     String    // "youtube", "tiktok", "instagram", "facebook", "linkedin", "x"
  scheduledFor DateTime
  status       String    @default("SCHEDULED") // SCHEDULED, PUBLISHED, FAILED, CANCELLED
  title        String?
  description  String?
  errorMessage String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId])
  @@index([clipId])
  @@index([status])
}

model AnalyticsSnapshot {
  id           String    @id @default(uuid())
  userId       String
  provider     String    // "all", "youtube", "tiktok", "instagram", "facebook", "linkedin", "x"
  date         DateTime  @default(now())
  views        Int       @default(0)
  likes        Int       @default(0)
  comments     Int       @default(0)
  shares       Int       @default(0)
  watchTimeSec Int       @default(0)
  engagementRate Float   @default(0)
  createdAt    DateTime  @default(now())

  @@index([userId])
  @@index([date])
}

model ApiKey {
  id           String    @id @default(uuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  key          String    @unique
  status       String    @default("ACTIVE") // ACTIVE, REVOKED
  requestLimit Int       @default(1000)
  requestCount Int       @default(0)
  lastUsedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId])
}

model WebhookSubscription {
  id           String    @id @default(uuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  url          String
  secret       String
  events       String    // JSON string array
  status       String    @default("ACTIVE") // ACTIVE, INACTIVE
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId])
}

model WorkflowRule {
  id           String    @id @default(uuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  trigger      String    // CLIP_GENERATED, VIDEO_UPLOADED, EXPORT_COMPLETED, etc.
  action       String    // AUTO_EXPORT, AUTO_PUBLISH, AUTO_TRANSCRIPT, etc.
  status       String    @default("ACTIVE") // ACTIVE, INACTIVE
  config       String    @default("{}") // JSON string config
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  executions   WorkflowExecution[]

  @@index([userId])
}

model WorkflowExecution {
  id           String    @id @default(uuid())
  ruleId       String
  rule         WorkflowRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  status       String    // RUNNING, SUCCESS, FAILED
  logs         String    @default("") // JSON string array
  errorMessage String?
  createdAt    DateTime  @default(now())

  @@index([ruleId])
}
